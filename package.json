{
  "name": "funkhub",
  "version": "0.1.0",
  "description": "A Friday Night Funkin Mod Launcher",
  "license": "GPL-3.0",
  "author": {
    "name": "ImMalloy",
    "email": "henrydraft.jpeg@gmail.com"
  },
  "homepage": "https://github.com/Crew-Awesome/FunkHub",
  "private": true,
  "type": "module",
  "main": "electron/main.cjs",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "electron:dev": "vite --host 127.0.0.1 --port 5173 & electron ./electron/main.cjs",
    "electron:start": "electron ./electron/main.cjs",
    "typecheck": "tsc --noEmit -p tsconfig.ci.json",
    "build:renderer": "vite build",
    "build:desktop:linux": "bun run build:renderer && node ./node_modules/electron-builder/cli.js --linux AppImage deb --x64 --publish never",
    "build:desktop:linux:appimage": "bun run build:renderer && node ./node_modules/electron-builder/cli.js --linux AppImage --x64 --publish never",
    "build:desktop:linux:deb": "bun run build:renderer && node ./node_modules/electron-builder/cli.js --linux deb --x64 --publish never",
    "build:desktop:win": "bun run build:renderer && node ./node_modules/electron-builder/cli.js --win nsis portable --x64 --publish never",
    "build:desktop:mac": "bun run build:renderer && node ./node_modules/electron-builder/cli.js --mac dmg --publish never"
  },
  "dependencies": {
    "7zip-bin": "^5.2.0",
    "@radix-ui/react-checkbox": "^1.3.3",
    "@radix-ui/react-dialog": "^1.1.15",
    "clsx": "^2.1.1",
    "lucide-react": "^0.555.0",
    "motion": "^12.23.24",
    "node-7z": "^3.0.0",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "react-router": "^7.9.4",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.5.0",
    "tw-animate-css": "^1.4.0"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.1.13",
    "@types/react": "^19.2.2",
    "@types/react-dom": "^19.2.2",
    "@vitejs/plugin-react": "^5.0.4",
    "electron": "^41.0.2",
    "electron-builder": "^26.8.1",
    "electron-updater": "^6.6.2",
    "tailwindcss": "^4.1.13",
    "typescript": "^5.9.2",
    "vite": "^7.1.7"
  },
  "build": {
    "appId": "com.funkhub.desktop",
    "productName": "FunkHub",
    "executableName": "funkhub",
    "directories": {
      "output": "dist-desktop"
    },
    "files": [
      "dist/**",
      "electron/**",
      "package.json"
    ],
    "asar": true,
    "icon": "build/icons/icon.png",
    "asarUnpack": [
      "node_modules/7zip-bin/**"
    ],
    "protocols": [
      {
        "name": "FunkHub Protocol",
        "schemes": [
          "funkhub"
        ]
      }
    ],
    "npmRebuild": false,
    "linux": {
      "target": [
        {
          "target": "AppImage",
          "arch": [
            "x64"
          ]
        },
        {
          "target": "deb",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "build/icons/linux",
      "category": "Game",
      "maintainer": "ImMalloy <henrydraft.jpeg@gmail.com>",
      "synopsis": "A Friday Night Funkin' mod launcher and manager.",
      "description": "FunkHub is a simple desktop application for discovering, installing, and launching Friday Night Funkin' mods. It helps you browse GameBanana mods, install into supported engines, manage engine instances, and launch content from one place.",
      "desktop": {
        "Name": "FunkHub",
        "Comment": "A Friday Night Funkin' mod launcher and manager.",
        "Icon": "funkhub",
        "Categories": "Game;",
        "Keywords": "fnf;friday-night-funkin;mods;mod-manager;launcher;gamebanana;",
        "StartupWMClass": "FunkHub"
      },
      "extraFiles": [
        {
          "from": "build/linux/funkhub.metainfo.xml",
          "to": "usr/share/metainfo/funkhub.metainfo.xml"
        },
        {
          "from": "assets/art/screenshots/funkhub-screenshot-discover.png",
          "to": "usr/share/funkhub/screenshots/funkhub-screenshot-discover.png"
        },
        {
          "from": "assets/art/screenshots/funkhub-screenshot-library.png",
          "to": "usr/share/funkhub/screenshots/funkhub-screenshot-library.png"
        },
        {
          "from": "assets/art/screenshots/funkhub-screenshot-engines.png",
          "to": "usr/share/funkhub/screenshots/funkhub-screenshot-engines.png"
        }
      ]
    },
    "mac": {
      "target": [
        "dmg",
        "zip"
      ],
      "icon": "build/icons/icon.icns"
    },
    "win": {
      "icon": "build/icons/icon.ico",
      "target": [
        "nsis",
        "portable"
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "installerIcon": "build/icons/icon.ico",
      "uninstallerIcon": "build/icons/icon.ico",
      "artifactName": "FunkHub Setup ${version}.${ext}",
      "shortcutName": "FunkHub"
    },
    "portable": {
      "artifactName": "FunkHub ${version}.${ext}"
    }
  }
}
