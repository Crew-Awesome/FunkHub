format_version: 1
project:
  name: FunkHub
  slug: funkhub
  web: https://github.com/Crew-Awesome/FunkHub
components:
  - name: App UI
    slug: app-ui
    source_language: en
    filemask: app/i18n/locales/*.json
    template: app/i18n/locales/en.json
    new_base: app/i18n/locales/en.json
    file_format: json
    new_lang: add
    language_code_style: bcp
    allow_translation_propagation: true
    manage_units: true
    check_flags: ""
